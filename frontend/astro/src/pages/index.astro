---
import BaseLayout from "../layouts/BaseLayout.astro";

// 公開設定（ヘルプセンター）
const supportUrl = import.meta.env.PUBLIC_SUPPORT_PORTAL_URL ?? 'https://support.recrubo.net';
// サポートサーバー招待（固定URL指定）
const supportServerUrl = 'https://discord.gg/tJAGc9aRdc';
// APIベース URL（環境変数で上書き可能 / 末尾スラッシュ除去）
const apiBaseUrl = (import.meta.env.PUBLIC_API_BASE_URL && import.meta.env.PUBLIC_API_BASE_URL.trim() !== '')
  ? import.meta.env.PUBLIC_API_BASE_URL.trim().replace(/\/$/, '')
  : 'https://api.recrubo.net';
// フォールバック（固定OAuth招待URL）: 環境変数で指定可能。未設定なら null 扱い
const fallbackInviteUrl = (import.meta.env.PUBLIC_DISCORD_INVITE_URL && import.meta.env.PUBLIC_DISCORD_INVITE_URL.trim() !== '')
  ? import.meta.env.PUBLIC_DISCORD_INVITE_URL.trim()
  : null;

// FAQ構造化データ（検索スニペット強化）
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Recruboとは何ですか？",
      acceptedAnswer: {
        "@type": "Answer",
        text: "RecruboはDiscordのゲーム募集を効率化するボットです。埋め込み画像で視覚的にわかりやすい募集投稿、フレンドコード管理、高速レスポンスでサーバー運営をサポートします。"
      }
    },
    {
      "@type": "Question",
      name: "Recruboは無料で使えますか？",
      acceptedAnswer: {
        "@type": "Answer",
        text: "はい、Recruboは完全無料でご利用いただけます。基本機能はすべて無料で提供しており、追加料金は一切かかりません。"
      }
    },
    {
      "@type": "Question",
      name: "Recruboをサーバーに導入する方法は？",
      acceptedAnswer: {
        "@type": "Answer",
        text: "公式サイトの招待ボタンをクリックし、Discordの認証画面でサーバーを選択するだけで導入完了です。管理者権限が必要です。"
      }
    },
    {
      "@type": "Question",
      name: "どのようなゲームの募集に対応していますか？",
      acceptedAnswer: {
        "@type": "Answer",
        text: "あらゆるゲームの募集に対応しています。FPS、MMORPG、カードゲーム、協力プレイなど、ジャンルを問わず利用できます。"
      }
    }
  ]
};
---
<BaseLayout>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>

  <section class="relative overflow-hidden pt-20 pb-16 sm:pt-24 sm:pb-20 lg:pt-28 lg:pb-24">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(255,126,66,0.18),transparent_40%),radial-gradient(circle_at_bottom_left,rgba(255,61,138,0.10),transparent_34%)]"></div>
    <div class="container relative z-10">
      <div class="grid items-center gap-12 lg:grid-cols-[1.1fr_0.9fr]">
        <div class="max-w-2xl animate-fade-in-up">
          <span class="inline-flex items-center rounded-full border border-brand-200 bg-white/80 px-4 py-2 text-sm font-medium text-brand-700 shadow-sm backdrop-blur">
            Discordのゲーム募集ボット
          </span>
          <h1 class="mt-6 text-4xl font-bold tracking-tight text-slate-900 sm:text-5xl lg:text-6xl">
            募集、フレコ、返信を
            <span class="bg-gradient-to-r from-brand-500 to-accent-500 bg-clip-text text-transparent">ひとつにまとめる。</span>
          </h1>
          <p class="mt-6 text-lg leading-8 text-slate-600 sm:text-xl">
            Recruboは、Discordの募集を見やすく整えて、フレンドコード管理と案内返信までまとめて支えるボットです。
          </p>

          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            <button
              type="button"
              class="btn-primary js-bot-invite px-6 py-3 text-base"
              data-label="Discordにボットを招待"
              data-fallback={fallbackInviteUrl || ''}
              data-api-base={apiBaseUrl}
            >
              Discordにボットを招待
            </button>
            <a href="#features" class="btn-secondary px-6 py-3 text-base">
              機能を見る
            </a>
            <a href={supportUrl} class="btn-secondary px-6 py-3 text-base" target="_blank" rel="noopener">
              サポート
            </a>
          </div>

          <div class="mt-8 grid max-w-xl gap-3 sm:grid-cols-3">
            <div class="rounded-2xl border border-brand-100 bg-white/70 p-4 backdrop-blur">
              <p class="text-sm font-semibold text-slate-900">募集投稿</p>
              <p class="mt-1 text-sm text-slate-600">見やすい埋め込み表示</p>
            </div>
            <div class="rounded-2xl border border-brand-100 bg-white/70 p-4 backdrop-blur">
              <p class="text-sm font-semibold text-slate-900">フレコ整理</p>
              <p class="mt-1 text-sm text-slate-600">一元管理で探しやすい</p>
            </div>
            <div class="rounded-2xl border border-brand-100 bg-white/70 p-4 backdrop-blur">
              <p class="text-sm font-semibold text-slate-900">高速応答</p>
              <p class="mt-1 text-sm text-slate-600">案内をすばやく返せる</p>
            </div>
          </div>
        </div>

        <div class="relative">
          <div class="absolute -inset-4 rounded-[2rem] bg-gradient-to-br from-brand-200/40 via-white/60 to-accent-200/30 blur-2xl"></div>
          <div class="relative overflow-hidden rounded-[2rem] border border-brand-100 bg-white/85 p-4 shadow-[0_30px_80px_rgba(255,126,66,0.14)] backdrop-blur">
            <div class="rounded-[1.5rem] border border-brand-100 bg-gradient-to-br from-brand-50 via-white to-rose-50 p-4 sm:p-6">
              <div class="flex items-center justify-between border-b border-brand-100 pb-3">
                <div>
                  <p class="text-sm font-semibold text-slate-900">Recrubo preview</p>
                  <p class="text-xs text-slate-500">やわらかい暖色トーンで統一</p>
                </div>
                <span class="rounded-full bg-brand-500/10 px-3 py-1 text-xs font-semibold text-brand-700">LIVE</span>
              </div>
              <div class="mt-4 overflow-hidden rounded-[1.25rem] border border-brand-100 bg-white shadow-sm">
                <img src="/シンプル募集.png" alt="Recruboのシンプルな募集表示サンプル" class="h-full w-full object-cover" loading="eager" />
              </div>
              <div class="mt-4 grid gap-3 sm:grid-cols-3">
                <div class="rounded-2xl bg-brand-50 p-4">
                  <p class="text-xs font-semibold uppercase tracking-[0.2em] text-brand-600">Step 1</p>
                  <p class="mt-2 text-sm font-medium text-slate-900">募集を作成</p>
                </div>
                <div class="rounded-2xl bg-amber-50 p-4">
                  <p class="text-xs font-semibold uppercase tracking-[0.2em] text-amber-600">Step 2</p>
                  <p class="mt-2 text-sm font-medium text-slate-900">見やすく整理</p>
                </div>
                <div class="rounded-2xl bg-rose-50 p-4">
                  <p class="text-xs font-semibold uppercase tracking-[0.2em] text-rose-600">Step 3</p>
                  <p class="mt-2 text-sm font-medium text-slate-900">すぐ参加へ案内</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="features" class="pb-16 sm:pb-20">
    <div class="container">
      <div class="max-w-2xl animate-fade-in-up">
        <p class="text-sm font-semibold uppercase tracking-[0.28em] text-brand-600">Features</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">
          伝えたいことを、3つに絞る。
        </h2>
        <p class="mt-4 text-lg leading-8 text-slate-600">
          情報を増やしすぎず、最初の一歩がすぐ見える構成にしています。
        </p>
      </div>

      <div class="mt-10 grid gap-6 lg:grid-cols-3">
        <a href="/commands/gameRecruit" class="card block animate-fade-in-up transition-transform duration-200 hover:-translate-y-1" style="animation-delay: 0.1s">
          <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-brand-500 text-white shadow-sm">
            <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
            </svg>
          </div>
          <h3 class="mt-5 text-xl font-semibold text-slate-900">募集を見やすくする</h3>
          <p class="mt-3 text-slate-600">
            埋め込み形式の募集で、参加したい人に内容が伝わりやすくなります。
          </p>
        </a>

        <a href="/commands/friendCode" class="card block animate-fade-in-up transition-transform duration-200 hover:-translate-y-1" style="animation-delay: 0.2s">
          <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-accent-500 text-white shadow-sm">
            <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V4a2 2 0 118 0v2m-4 0a2 2 0 104 0m-4 0a2 2 0 014 0z"></path>
            </svg>
          </div>
          <h3 class="mt-5 text-xl font-semibold text-slate-900">フレコをまとめる</h3>
          <p class="mt-3 text-slate-600">
            各種フレンドコードを一元管理して、メンバー同士の導線を短くします。
          </p>
        </a>

        <a href="/commands/fastResponse" class="card block animate-fade-in-up transition-transform duration-200 hover:-translate-y-1" style="animation-delay: 0.3s">
          <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-gradient-to-br from-brand-500 to-accent-500 text-white shadow-sm">
            <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
          <h3 class="mt-5 text-xl font-semibold text-slate-900">返信を速くする</h3>
          <p class="mt-3 text-slate-600">
            反応の早い案内で、募集から参加までの流れを止めません。
          </p>
        </a>
      </div>
    </div>
  </section>

  <section id="invite" class="pb-20 sm:pb-24">
    <div class="container">
      <div class="rounded-[2rem] border border-brand-200 bg-gradient-to-r from-brand-500 via-brand-500 to-accent-500 px-6 py-10 text-white shadow-[0_24px_70px_rgba(255,126,66,0.25)] sm:px-8 lg:px-10">
        <div class="grid gap-8 lg:grid-cols-[1fr_auto] lg:items-center">
          <div class="max-w-2xl">
            <p class="text-sm font-semibold uppercase tracking-[0.28em] text-white/80">Get Started</p>
            <h2 class="mt-3 text-3xl font-bold tracking-tight sm:text-4xl">
              まずはボットを入れて、雰囲気を見てください。
            </h2>
            <p class="mt-4 text-base leading-7 text-white/85 sm:text-lg">
              公式サーバーでも案内しています。導入後の設定や使い方はサポートから確認できます。
            </p>
          </div>
          <div class="flex flex-col gap-3 sm:flex-row lg:flex-col">
            <button type="button" class="js-bot-invite inline-flex justify-center rounded-full bg-white px-6 py-3 text-base font-semibold text-brand-700 shadow-sm transition-transform duration-200 hover:-translate-y-0.5" data-label="Discordにボットを招待" data-fallback={fallbackInviteUrl || ''} data-api-base={apiBaseUrl}>
              Discordにボットを招待
            </button>
            <a href={supportServerUrl} class="inline-flex justify-center rounded-full border border-white/35 bg-white/10 px-6 py-3 text-base font-semibold text-white backdrop-blur transition-colors hover:bg-white/15" target="_blank" rel="noopener">
              サポートサーバーに参加
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  async function fetchInviteUrl(apiBaseOverride) {
    try {
      const baseUrl = apiBaseOverride ? apiBaseOverride.replace(/\/$/, '') : window.location.origin;
      const endpoint = new URL('/api/bot-invite', baseUrl).toString();
      const res = await fetch(endpoint, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json; charset=utf-8' }
      });
      if (!res.ok) throw new Error('bad status');
      const data = await res.json();
      return data && (data.url || data.inviteUrl) ? (data.url || data.inviteUrl) : null;
    } catch (e) {
      return null;
    }
  }

  async function handleInviteClick(e) {
    e.preventDefault();
    const el = e.currentTarget;
    const originalText = el.dataset.label || el.textContent || '今すぐボットを招待';
    const fallbackUrl = el.dataset.fallback || '';
    const apiBaseOverride = el.dataset.apiBase || window.location.origin;
    let finalUrl = '';

    el.classList.add('opacity-70', 'pointer-events-none');
    el.textContent = '生成中...';

    try {
      const dynamicUrl = await fetchInviteUrl(apiBaseOverride);
      finalUrl = dynamicUrl || fallbackUrl;

      if (!finalUrl) {
        throw new Error('invite_url_unavailable');
      }

      window.location.href = finalUrl;
    } catch (error) {
      if (fallbackUrl) {
        window.location.href = fallbackUrl;
      } else {
        window.location.href = finalUrl || window.location.origin;
      }
    } finally {
      el.classList.remove('opacity-70', 'pointer-events-none');
      el.textContent = originalText;
    }
  }

  document.querySelectorAll('.js-bot-invite').forEach(el => {
    el.addEventListener('click', handleInviteClick);
  });
</script>
