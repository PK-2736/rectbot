---
import BaseLayout from "../../layouts/BaseLayout.astro";

const title = "コマンド一覧";
const description = "Recruboで使えるコマンドの一覧ページです。募集、テンプレート、フレンドコード、高速返信機能への導線をまとめています。";
const commandGroups = [
  {
    heading: '募集・テンプレート',
    description: '募集の作成、編集、テンプレート運用を行うコマンドです。',
    href: '/commands/gameRecruit',
    cta: '募集コマンドを見る',
    commands: ['/rect', '/rect_template', '/setting', '/rect-edit', '/rect-close']
  },
  {
    heading: 'フレンドコード管理',
    description: 'プラットフォームごとのフレンドコード管理を効率化します。',
    href: '/commands/friendCode',
    cta: 'フレンドコード機能を見る',
    commands: ['/friend-code add', '/friend-code list', '/friend-code delete']
  },
  {
    heading: '高速返信',
    description: 'よく使う案内を短い操作で素早く返信できます。',
    href: '/commands/fastResponse',
    cta: '高速返信機能を見る',
    commands: ['/quick add', '/quick list', '/quick send']
  }
];
---

<BaseLayout title={`${title} - Recrubo`} description={description}>
  <section class="relative overflow-hidden py-20 sm:py-24">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(217,137,79,0.16),transparent_42%),radial-gradient(circle_at_bottom_left,rgba(201,115,61,0.12),transparent_38%)]"></div>
    <div class="container relative z-10">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-semibold uppercase tracking-[0.28em] text-brand-600">Commands</p>
        <h1 class="mt-4 text-4xl font-bold tracking-tight text-slate-900 sm:text-5xl">
          Recrubo コマンド一覧
        </h1>
        <p class="mt-5 text-lg leading-8 text-slate-600">
          機能ごとに使い方をまとめています。まずは募集機能から確認するとスムーズです。
        </p>
      </div>

      <div class="mx-auto mt-12 grid max-w-5xl gap-6 lg:grid-cols-3">
        {commandGroups.map((group, index) => (
          <article class="rounded-3xl border border-brand-100 bg-white/90 p-6 shadow-sm backdrop-blur transition duration-200 hover:-translate-y-1 hover:shadow-md" style={`animation-delay: ${0.08 * (index + 1)}s`}>
            <h2 class="text-xl font-bold text-slate-900">{group.heading}</h2>
            <p class="mt-3 text-sm leading-6 text-slate-600">{group.description}</p>
            <ul class="mt-4 space-y-2">
              {group.commands.map((command) => (
                <li class="rounded-xl border border-brand-100 bg-brand-50/50 px-3 py-2 text-sm font-medium text-brand-800">{command}</li>
              ))}
            </ul>
            <a href={group.href} class="mt-5 inline-flex items-center rounded-full border border-brand-200 bg-white px-4 py-2 text-sm font-semibold text-brand-700 transition-colors hover:bg-brand-50">
              {group.cta}
            </a>
          </article>
        ))}
      </div>

      <div class="mx-auto mt-10 max-w-4xl rounded-3xl border border-brand-200 bg-gradient-to-r from-brand-500 to-accent-500 px-6 py-8 text-white shadow-[0_20px_55px_rgba(201,115,61,0.24)] sm:px-8">
        <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.22em] text-white/85">Premium</p>
            <p class="mt-2 text-lg font-semibold">テンプレート機能や拡張設定はサブスク画面から確認できます。</p>
          </div>
          <a href="https://dash.recrubo.net/subscription" class="inline-flex items-center justify-center rounded-full bg-white px-5 py-3 text-sm font-semibold text-brand-700 transition-transform hover:-translate-y-0.5">
            サブスク画面へ
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
